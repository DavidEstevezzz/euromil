---
import Layout from '../../layouts/Layout.astro';
const claseInput =
  'w-full rounded-xl border border-carbon/15 bg-crema px-3 py-2 text-sm outline-none focus:border-terracota focus:ring-2 focus:ring-terracota/30';
---
<Layout title="Panel de reservas · Euromil" description="Panel privado de gestión de reservas">
  <!-- LOGIN -->
  <div id="vista-login" class="flex min-h-screen items-center justify-center px-4">
    <form id="form-login" class="w-full max-w-sm rounded-2xl bg-white p-8 shadow-lg">
      <p class="text-center font-display text-2xl font-bold text-terracota">🐾 Euromil</p>
      <p class="mt-1 text-center text-sm text-carbon/60">Panel de reservas</p>
      <label for="login-email" class="mt-6 mb-1.5 block text-sm font-semibold">Email</label>
      <input id="login-email" type="email" required class={claseInput} autocomplete="username" />
      <label for="login-pass" class="mt-4 mb-1.5 block text-sm font-semibold">Contraseña</label>
      <input id="login-pass" type="password" required class={claseInput} autocomplete="current-password" />
      <p id="login-error" class="mt-3 hidden text-sm font-medium text-terracota"></p>
      <button type="submit" class="mt-6 w-full rounded-full bg-terracota py-3 font-semibold text-crema transition hover:brightness-110">
        Entrar
      </button>
    </form>
  </div>

  <!-- PANEL -->
  <div id="vista-panel" class="hidden min-h-screen">
    <header class="sticky top-0 z-40 border-b border-carbon/10 bg-white">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <p class="font-display text-lg font-bold text-terracota">🐾 Reservas</p>
        <div class="flex items-center gap-3">
          <button id="btn-nueva" class="rounded-full bg-ocre px-4 py-2 text-sm font-semibold text-carbon hover:brightness-105">
            + Reserva manual
          </button>
          <button id="btn-logout" class="text-sm font-medium text-carbon/60 hover:text-terracota">Salir</button>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8">
      <!-- Formulario reserva manual -->
      <form id="form-manual" class="mb-8 hidden rounded-2xl bg-white p-6 shadow-md">
        <h2 class="font-display text-lg font-bold">Nueva reserva manual</h2>
        <p class="mt-1 text-sm text-carbon/60">Para reservas recibidas por teléfono o email.</p>
        <div class="mt-5 grid gap-4 sm:grid-cols-3">
          <div>
            <label class="mb-1 block text-xs font-semibold">Perro *</label>
            <input name="perro" required class={claseInput} />
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Raza</label>
            <input name="raza" class={claseInput} />
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Tamaño</label>
            <select name="tamano" class={claseInput}>
              <option value="pequeno">Pequeño</option>
              <option value="mediano" selected>Mediano</option>
              <option value="grande">Grande</option>
            </select>
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Dueño/a *</label>
            <input name="dueno" required class={claseInput} />
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Teléfono *</label>
            <input name="telefono" required class={claseInput} />
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Email</label>
            <input name="email" type="email" class={claseInput} />
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Entrada *</label>
            <input name="entrada" id="m-entrada" type="date" required class={claseInput} />
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Hora entrega *</label>
            <select name="hora_entrada" id="m-hora-entrada" required class={claseInput}>
              <option value="">Elige fecha…</option>
            </select>
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Servicio *</label>
            <select name="servicio" required class={claseInput}>
              <option value="estancia">Estancia</option>
              <option value="pension">Pensión</option>
              <option value="guarderia">Hotel 24h / Guardería</option>
            </select>
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Salida *</label>
            <input name="salida" id="m-salida" type="date" required class={claseInput} />
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Hora recogida *</label>
            <select name="hora_salida" id="m-hora-salida" required class={claseInput}>
              <option value="">Elige fecha…</option>
            </select>
          </div>
          <div>
            <label class="mb-1 block text-xs font-semibold">Origen *</label>
            <select name="origen" required class={claseInput}>
              <option value="telefono">📞 Teléfono</option>
              <option value="email">✉️ Email</option>
            </select>
          </div>
        </div>
        <div class="mt-4 flex flex-wrap items-center gap-4">
          <label class="flex items-center gap-2 text-sm">
            <input name="vacunas" type="checkbox" class="h-4 w-4 accent-salvia" />
            Cartilla de vacunas comprobada
          </label>
          <label class="flex items-center gap-2 text-sm">
            Estado:
            <select name="estado" class="rounded-lg border border-carbon/15 bg-crema px-2 py-1 text-sm">
              <option value="confirmada" selected>Confirmada</option>
              <option value="pendiente">Pendiente</option>
            </select>
          </label>
        </div>
        <div class="mt-5 flex gap-3">
          <button type="submit" class="rounded-full bg-salvia px-6 py-2.5 text-sm font-semibold text-crema hover:brightness-110">
            Guardar reserva
          </button>
          <button type="button" id="btn-cancelar-manual" class="text-sm font-medium text-carbon/60 hover:text-terracota">
            Cancelar
          </button>
        </div>
      </form>

      <!-- Filtros -->
      <div class="flex flex-wrap gap-2" id="filtros">
        <button data-filtro="pendiente" class="filtro rounded-full px-4 py-1.5 text-sm font-semibold">Pendientes <span id="n-pendiente"></span></button>
        <button data-filtro="confirmada" class="filtro rounded-full px-4 py-1.5 text-sm font-semibold">Confirmadas <span id="n-confirmada"></span></button>
        <button data-filtro="todas" class="filtro rounded-full px-4 py-1.5 text-sm font-semibold">Todas</button>
      </div>

      <div id="lista-reservas" class="mt-6 space-y-4"></div>
      <p id="lista-vacia" class="hidden py-16 text-center text-carbon/50">
        No hay reservas en esta vista.
      </p>
    </main>
  </div>
</Layout>

<script>
  import { MOCK_MODE } from '../../lib/config';
  import { listarReservas, cambiarEstado, crearReservaManual, aplicarOverrides } from '../../lib/reservas';
  import { franjasParaFecha } from '../../lib/horarios';

  const $ = (id) => document.getElementById(id);
  const vistaLogin = $('vista-login');
  const vistaPanel = $('vista-panel');
  let filtroActual = 'pendiente';
  let reservas = [];

  // ---------- AUTH ----------
  const MOCK_USER = 'admin@euromil.demo';
  const MOCK_PASS = 'demo1234';

  async function haySesion() {
    if (MOCK_MODE) return localStorage.getItem('euromil_admin') === '1';
    const { supabase } = await import('../../lib/supabase');
    const { data } = await supabase.auth.getSession();
    return !!data.session;
  }

  async function login(email, pass) {
    if (MOCK_MODE) {
      if (email === MOCK_USER && pass === MOCK_PASS) {
        localStorage.setItem('euromil_admin', '1');
        return { ok: true };
      }
      return { ok: false, msg: 'Credenciales incorrectas (demo: admin@euromil.demo / demo1234)' };
    }
    const { supabase } = await import('../../lib/supabase');
    const { error } = await supabase.auth.signInWithPassword({ email, password: pass });
    return { ok: !error, msg: error ? 'Email o contraseña incorrectos.' : '' };
  }

  async function logout() {
    if (MOCK_MODE) {
      localStorage.removeItem('euromil_admin');
    } else {
      const { supabase } = await import('../../lib/supabase');
      await supabase.auth.signOut();
    }
    location.reload();
  }

  // ---------- RENDER ----------
  const etiquetaServicio = { estancia: 'Estancia', pension: 'Pensión', guarderia: 'Hotel 24h' };
  const iconoOrigen = { web: '🌐 web', telefono: '📞 teléfono', email: '✉️ email' };
  const badgeEstado = {
    pendiente: 'bg-ocre/20 text-carbon',
    confirmada: 'bg-salvia/20 text-salvia',
    rechazada: 'bg-terracota/15 text-terracota',
  };

  function fFecha(f) {
    return new Date(f + 'T00:00:00').toLocaleDateString('es-ES', { day: 'numeric', month: 'short' });
  }

  function tarjeta(r) {
    return `
      <article class="rounded-2xl bg-white p-5 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="font-display text-lg font-bold">${r.perro}
              <span class="ml-1 text-sm font-normal text-carbon/50">${r.raza || ''} · ${r.tamano || ''}</span>
            </p>
            <p class="mt-1 text-sm text-carbon/70">
              ${fFecha(r.entrada)} ${r.hora_entrada} → ${fFecha(r.salida)} ${r.hora_salida}
              · ${etiquetaServicio[r.servicio] || r.servicio}
            </p>
            <p class="mt-1 text-sm">
              ${r.dueno} · <a href="tel:${(r.telefono || '').replace(/\s/g, '')}" class="font-semibold text-terracota">${r.telefono}</a>
              ${r.email ? ` · <span class="text-carbon/60">${r.email}</span>` : ''}
            </p>
            ${!r.vacunas ? '<p class="mt-2 inline-block rounded-lg bg-terracota/10 px-2 py-1 text-xs font-semibold text-terracota">⚠ Cartilla de vacunas sin confirmar</p>' : ''}
          </div>
          <div class="flex flex-col items-end gap-2">
            <span class="rounded-full px-3 py-1 text-xs font-semibold ${badgeEstado[r.estado]}">${r.estado}</span>
            <span class="text-xs text-carbon/50">${iconoOrigen[r.origen] || r.origen}</span>
          </div>
        </div>
        ${r.estado === 'pendiente' ? `
        <div class="mt-4 flex gap-3 border-t border-carbon/10 pt-4">
          <button data-accion="confirmada" data-id="${r.id}" class="rounded-full bg-salvia px-5 py-2 text-sm font-semibold text-crema hover:brightness-110">✓ Confirmar</button>
          <button data-accion="rechazada" data-id="${r.id}" class="rounded-full border border-terracota px-5 py-2 text-sm font-semibold text-terracota hover:bg-terracota hover:text-crema">✕ Rechazar</button>
        </div>` : ''}
      </article>`;
  }

  function pintar() {
    const visibles = filtroActual === 'todas' ? reservas : reservas.filter((r) => r.estado === filtroActual);
    $('lista-reservas').innerHTML = visibles.map(tarjeta).join('');
    $('lista-vacia').classList.toggle('hidden', visibles.length > 0);

    $('n-pendiente').textContent = `(${reservas.filter((r) => r.estado === 'pendiente').length})`;
    $('n-confirmada').textContent = `(${reservas.filter((r) => r.estado === 'confirmada').length})`;

    document.querySelectorAll('.filtro').forEach((b) => {
      const activo = b.dataset.filtro === filtroActual;
      b.className = `filtro rounded-full px-4 py-1.5 text-sm font-semibold ${
        activo ? 'bg-carbon text-crema' : 'bg-white text-carbon/70 hover:bg-carbon/5'
      }`;
    });
  }

  async function cargar() {
    const res = await listarReservas();
    reservas = MOCK_MODE ? aplicarOverrides(res.data) : res.data;
    pintar();
  }

  // ---------- EVENTOS ----------
  $('form-login').addEventListener('submit', async (e) => {
    e.preventDefault();
    const res = await login($('login-email').value.trim(), $('login-pass').value);
    if (res.ok) {
      vistaLogin.classList.add('hidden');
      vistaPanel.classList.remove('hidden');
      cargar();
    } else {
      const err = $('login-error');
      err.textContent = res.msg;
      err.classList.remove('hidden');
    }
  });

  $('btn-logout').addEventListener('click', logout);

  $('lista-reservas').addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-accion]');
    if (!btn) return;
    if (btn.dataset.accion === 'rechazada' && !confirm('¿Rechazar esta reserva?')) return;
    await cambiarEstado(btn.dataset.id, btn.dataset.accion);
    cargar();
  });

  document.querySelectorAll('.filtro').forEach((b) =>
    b.addEventListener('click', () => { filtroActual = b.dataset.filtro; pintar(); })
  );

  // Reserva manual
  $('btn-nueva').addEventListener('click', () => $('form-manual').classList.toggle('hidden'));
  $('btn-cancelar-manual').addEventListener('click', () => $('form-manual').classList.add('hidden'));

  function franjasEn(inputId, selectId) {
    $(inputId).addEventListener('change', () => {
      const franjas = franjasParaFecha($(inputId).value);
      $(selectId).innerHTML = franjas.length
        ? '<option value="">Hora…</option>' + franjas.map((f) => `<option>${f}</option>`).join('')
        : '<option value="">Domingo: cerrado</option>';
    });
  }
  franjasEn('m-entrada', 'm-hora-entrada');
  franjasEn('m-salida', 'm-hora-salida');

  $('form-manual').addEventListener('submit', async (e) => {
    e.preventDefault();
    const datos = Object.fromEntries(new FormData(e.target).entries());
    datos.vacunas = !!datos.vacunas;
    const res = await crearReservaManual(datos);
    if (res.ok) {
      e.target.reset();
      $('form-manual').classList.add('hidden');
      cargar();
    } else {
      alert('No se pudo guardar la reserva.');
    }
  });

  // ---------- INIT ----------
  (async () => {
    if (await haySesion()) {
      vistaLogin.classList.add('hidden');
      vistaPanel.classList.remove('hidden');
      cargar();
    }
  })();
</script>