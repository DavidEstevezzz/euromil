---
import Escena from './Escena.astro';
// Para fotos reales: sustituye cada <Escena/> por <img src="/images/galeria-1.jpg" .../>
const galeria = [
  { tipo: 'exterior', etiqueta: 'Zona exterior' },
  { tipo: 'descanso', etiqueta: 'Descanso' },
  { tipo: 'juego',    etiqueta: 'Ratos de juego' },
  { tipo: 'interior', etiqueta: 'Su rincón' },
] as const;
---
<section id="nosotros" class="mx-auto max-w-6xl px-4 py-20 md:py-28">
  <div class="grid items-center gap-12 md:grid-cols-2">
    <div>
      <p class="antetitulo">La residencia</p>
      <h2 class="mt-3 font-display text-3xl font-semibold md:text-[2.6rem] md:leading-tight">
        Un sitio donde tu perro está{' '}
        <span class="text-terracota">a gusto de verdad</span>
      </h2>
      <p class="mt-5 leading-relaxed text-carbon/75">
        Euromil está en el Camino de La Atalaya, en Cogollos de la Vega: campo,
        silencio y aire de sierra a un cuarto de hora de Granada. Aquí los perros
        no pasan el día encerrados en un box de un polígono industrial — tienen
        espacio, rutina de paseos y compañía.
      </p>

      <ul class="mt-7 space-y-3.5 text-carbon/80">
        {[
          'Entorno rural tranquilo, sin ruido de tráfico',
          'Instalaciones limpias y amplias, higiene diaria',
          'Trato directo con Andrés, sin intermediarios',
        ].map((t) => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-salvia/15 text-sm text-salvia-oscuro">✓</span>
            {t}
          </li>
        ))}
      </ul>

      <!-- Nota personal de Andrés -->
      <figure class="mt-8 rounded-2xl border-l-4 border-ocre bg-hueso/70 p-5">
        <blockquote class="font-display text-lg italic leading-snug text-carbon/85">
          «Conozco el carácter, las manías y la comida de cada huésped. Si te
          quedas más tranquilo, te voy contando cómo lo lleva tu perro durante
          la estancia.»
        </blockquote>
        <figcaption class="mt-3 flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-full bg-terracota text-crema" aria-hidden="true">🧑‍🌾</span>
          <span>
            <span class="block font-display text-base font-semibold not-italic text-carbon">Andrés</span>
            <span class="block text-xs text-carbon/55">al frente de la residencia</span>
          </span>
        </figcaption>
      </figure>
    </div>

    <div class="grid grid-cols-2 gap-3 md:gap-4">
      {galeria.map((foto, i) => (
        <Escena
          tipo={foto.tipo}
          etiqueta={foto.etiqueta}
          class={`aspect-[4/3] w-full rounded-2xl shadow-suave ring-1 ring-carbon/5 ${i % 2 === 1 ? 'mt-6' : ''}`}
        />
      ))}
    </div>
  </div>
</section>
