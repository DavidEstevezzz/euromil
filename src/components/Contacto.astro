---
const horario = [
  { dia: 'Lunes a jueves', horas: '9:00 – 20:00' },
  { dia: 'Viernes', horas: '10:00 – 21:00' },
  { dia: 'Sábado', horas: '10:30 – 14:00' },
  { dia: 'Domingo', horas: 'Cerrado' },
];
---
<section id="contacto" class="mx-auto max-w-6xl px-4 py-20 md:py-28">
  <div class="grid gap-10 md:grid-cols-2">
    <div>
      <p class="antetitulo">Contacto</p>
      <h2 class="mt-3 font-display text-3xl font-semibold md:text-[2.6rem] md:leading-tight">Ven a conocernos</h2>
      <p class="mt-4 flex items-start gap-2 text-carbon/70">
        <span aria-hidden="true">📍</span>
        Camino de La Atalaya · 18211 Cogollos de la Vega, Granada
      </p>

      <a
        href="tel:697681869"
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-terracota px-7 py-3.5 font-semibold text-crema shadow-calida transition hover:-translate-y-0.5 hover:brightness-110"
      >
        📞 Llámanos: 697 68 18 69
      </a>

      <h3 class="mt-9 font-display text-lg font-semibold">Horario de entregas y recogidas</h3>
      <div class="tarjeta mt-3 max-w-sm overflow-hidden p-0">
        <table class="w-full text-sm">
          <tbody>
            {horario.map((h) => (
              <tr class="border-b border-carbon/8 last:border-0">
                <td class="px-4 py-3 font-medium">{h.dia}</td>
                <td class={`px-4 py-3 text-right ${h.horas === 'Cerrado' ? 'font-semibold text-terracota' : 'text-carbon/70'}`}>
                  {h.horas}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="overflow-hidden rounded-3xl shadow-flotante ring-1 ring-carbon/10">
      <iframe
        src="https://maps.google.com/maps?q=37.288987,-3.575520&z=15&output=embed"
        title="Ubicación de Residencia Canina Euromil en Cogollos de la Vega"
        class="h-80 w-full border-0 md:h-full"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>
