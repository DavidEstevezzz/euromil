---
const servicios = [
  {
    icono: '🏡',
    titulo: 'Estancia canina',
    desc: 'Residencia por días: vacaciones, puentes o fines de semana. Tu perro con su rutina de paseos, comida y descanso en el campo.',
    detalle: 'Estancias desde 1 noche',
  },
  {
    icono: '🐕',
    titulo: 'Pensión para perros',
    desc: 'Estancias largas con seguimiento personalizado. Ideal para mudanzas, viajes de trabajo o temporadas fuera.',
    detalle: 'Descuentos por larga estancia',
  },
  {
    icono: '🌙',
    titulo: 'Hotel 24h · Guardería',
    desc: 'Atención continua día y noche. También guardería por horas o días sueltos si solo necesitas cubrir una jornada.',
    detalle: 'Supervisión las 24 horas',
  },
];
---
<section id="servicios" class="bg-salvia/10 py-16 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="revelar mx-auto max-w-2xl text-center">
      <p class="antetitulo justify-center">Servicios</p>
      <h2 class="mt-3 font-display text-3xl font-semibold md:text-[2.6rem] md:leading-tight">
        Lo que necesites, el tiempo que lo necesites
      </h2>
      <p class="mt-4 text-carbon/70">
        Cada perro y cada familia son distintos. Cuéntanos tu caso y te decimos
        qué opción encaja mejor — la tarifa depende de la duración y el tamaño.
      </p>
    </div>

    <div class="mt-10 grid gap-5 sm:gap-6 md:mt-14 md:grid-cols-3">
      {servicios.map((s) => (
        <article class="tarjeta revelar group relative flex flex-col p-6 transition duration-300 hover:-translate-y-1.5 hover:shadow-calida sm:p-7">
          <span class="grid h-16 w-16 place-items-center rounded-blob bg-ocre/15 text-3xl transition-transform duration-300 group-hover:rotate-6" aria-hidden="true">{s.icono}</span>

          <h3 class="mt-5 font-display text-xl font-semibold">{s.titulo}</h3>

          <p class="mt-3 flex-1 text-sm leading-relaxed text-carbon/70">{s.desc}</p>

          <p class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-salvia-oscuro">
            <span class="h-1.5 w-1.5 rounded-full bg-salvia"></span>{s.detalle}
          </p>

          <a
            href="#reservar"
            class="toca mt-5 rounded-full border-2 border-terracota/70 px-5 py-3 text-center text-sm font-semibold text-terracota transition hover:bg-terracota hover:text-crema"
          >
            Consultar tarifas
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
