---
const items = [
  { icono: '★★★★★', titulo: '5,0 en Google', desc: 'cerca de 90 reseñas', estrellas: true },
  { icono: '🌿', titulo: 'Entorno rural', desc: 'tranquilidad y aire libre, sin ruido de ciudad' },
  { icono: '🤝', titulo: 'Trato personal', desc: 'Andrés te cuenta cómo va tu perro cada día' },
];
---
<section class="relative z-10 -mt-12 px-4">
  <div class="tarjeta revelar mx-auto max-w-4xl divide-y divide-carbon/10 p-4 shadow-flotante sm:grid sm:grid-cols-3 sm:divide-y-0 sm:p-8">
    {items.map((it, i) => (
      <div class={`flex items-center gap-4 px-1 py-3 text-left sm:block sm:py-0 sm:text-center ${i === 1 ? 'sm:border-x sm:border-carbon/10' : ''} sm:px-2`}>
        <span
          class={`grid h-12 w-12 shrink-0 place-items-center rounded-full bg-ocre/12 sm:mx-auto sm:h-auto sm:w-auto sm:rounded-none sm:bg-transparent sm:text-2xl sm:tracking-wide ${it.estrellas ? 'text-[0.62rem] leading-none tracking-tighter text-ocre sm:text-2xl' : 'text-xl'}`}
          aria-hidden="true"
        >{it.icono}</span>
        <span class="min-w-0 sm:block">
          <span class="block font-display text-lg font-semibold leading-tight sm:mt-1.5 sm:text-xl">{it.titulo}</span>
          <span class="mt-0.5 block text-sm text-carbon/60">{it.desc}</span>
        </span>
      </div>
    ))}
  </div>
</section>
