---
// ⚠️ Testimonios de EJEMPLO para la demo. Sustituir por reseñas reales
// de la ficha de Google (con permiso o citando "Reseña de Google").
const testimonios = [
  {
    nombre: 'María J.',
    perro: 'Trufa, bodeguero',
    texto: 'Era la primera vez que dejábamos a Trufa y estábamos muertos de miedo. Andrés nos mandó fotos durante la semana y la recogimos feliz y tranquila. Las instalaciones, limpísimas y muy amplias.',
  },
  {
    nombre: 'Francisco R.',
    perro: 'Rocco, pastor alemán',
    texto: 'Rocco es grande y nervioso y en otras residencias lo pasaba mal. Aquí, con el campo alrededor y sus paseos, viene otro perro. Se nota que Andrés trata a cada uno según su carácter.',
  },
  {
    nombre: 'Carmen L.',
    perro: 'Nala, mestiza',
    texto: 'Lo que más me gustó es la tranquilidad del sitio: nada de ladridos histéricos ni jaulas apretadas. Nala volvió a casa relajada y hasta con mejor comportamiento. Repetiremos en verano seguro.',
  },
  {
    nombre: 'Javier M.',
    perro: 'Coco, caniche',
    texto: 'Trato cercano de verdad. Le expliqué a Andrés la medicación de Coco y se la dio a sus horas sin problema. Da mucha confianza dejar al perro con alguien que se nota que quiere a los animales.',
  },
];
const inicial = (n: string) => n.trim().charAt(0);
---
<section id="opiniones" class="mx-auto max-w-6xl px-4 py-16 md:py-28">
  <div class="revelar mx-auto max-w-2xl text-center">
    <p class="antetitulo justify-center">Opiniones</p>
    <h2 class="mt-3 font-display text-3xl font-semibold md:text-[2.6rem] md:leading-tight">
      Lo que cuentan las familias que ya nos conocen
    </h2>
    <p class="mt-4 inline-flex items-center gap-2 rounded-full bg-hueso px-4 py-1.5 text-sm text-carbon/70 shadow-suave">
      <span class="text-ocre">★★★★★</span> <strong class="text-carbon">5,0</strong> · cerca de 90 reseñas en Google
    </p>
  </div>

  <div class="mt-10 grid gap-5 sm:mt-14 sm:grid-cols-2 sm:gap-6 lg:grid-cols-4">
    {testimonios.map((t) => (
      <figure class="tarjeta revelar relative flex flex-col p-6">
        <span class="pointer-events-none absolute right-5 top-2 font-display text-6xl leading-none text-ocre/25" aria-hidden="true">”</span>
        <p class="text-ocre" aria-label="5 estrellas">★★★★★</p>
        <blockquote class="mt-3 flex-1 text-sm leading-relaxed text-carbon/80">
          {t.texto}
        </blockquote>
        <figcaption class="mt-5 flex items-center gap-3 border-t border-carbon/10 pt-4">
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-salvia/20 font-display text-lg font-semibold text-salvia-oscuro" aria-hidden="true">{inicial(t.nombre)}</span>
          <span>
            <span class="block text-sm font-semibold text-carbon">{t.nombre}</span>
            <span class="block text-xs text-carbon/50">{t.perro}</span>
          </span>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
