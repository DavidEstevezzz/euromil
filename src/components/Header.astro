---
const enlaces = [
  { href: '/#nosotros', texto: 'La residencia', icono: '🏡' },
  { href: '/#servicios', texto: 'Servicios', icono: '🐕' },
  { href: '/#opiniones', texto: 'Opiniones', icono: '⭐' },
  { href: '/#faq', texto: 'Preguntas', icono: '❓' },
  { href: '/#contacto', texto: 'Contacto', icono: '📍' },
  { href: '/consulta', texto: 'Mi reserva', icono: '🔎' },
];
---
<header class="sticky top-0 z-50 border-b border-carbon/8 bg-crema/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href="/#top" class="flex items-center gap-2 font-display text-xl font-semibold text-terracota">
      <span class="grid h-9 w-9 place-items-center rounded-full bg-terracota text-base text-crema">🐾</span>
      Euromil
    </a>

    <nav class="hidden items-center gap-6 md:flex">
  {enlaces.map((e) => (
    <a
      href={e.href}
      class="text-sm font-medium text-carbon/80 transition hover:text-terracota"
    >
      {e.texto}
    </a>
  ))}

  <a
    href="/#reservar"
    class="rounded-full bg-ocre px-5 py-2 text-sm font-semibold text-carbon shadow-suave transition hover:-translate-y-0.5 hover:brightness-105"
  >
    Reservar
  </a>
</nav>

    <button
      id="btn-menu"
      class="toca grid h-11 w-11 place-items-center rounded-full border border-carbon/10 bg-hueso/70 text-carbon shadow-suave md:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="menu-movil"
    >
      <svg id="icono-abrir" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icono-cerrar" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Menú móvil -->
  <div id="menu-backdrop" class="menu-backdrop fixed inset-0 top-[57px] z-40 hidden bg-carbon/35 backdrop-blur-sm md:hidden"></div>
  <nav
    id="menu-movil"
    class="menu-panel fixed inset-x-0 top-[57px] z-50 hidden max-h-[calc(100dvh-57px)] overflow-y-auto border-t border-carbon/10 bg-crema px-4 pb-6 pt-3 shadow-flotante md:hidden"
  >
    <ul class="grid gap-1.5">
      {enlaces.map((e) => (
        <li>
          <a
            href={e.href}
            class="toca flex items-center gap-3.5 rounded-2xl border border-transparent bg-hueso/60 px-4 py-3.5 text-base font-medium text-carbon transition active:border-terracota/30 active:bg-hueso"
            data-link-movil
          >
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-terracota/10 text-lg" aria-hidden="true">{e.icono}</span>
            <span class="flex-1">{e.texto}</span>
            <span class="text-carbon/30" aria-hidden="true">›</span>
          </a>
        </li>
      ))}
    </ul>

    <a
      href="/#reservar"
      data-link-movil
      class="toca mt-4 flex items-center justify-center gap-2 rounded-full bg-ocre px-5 py-4 text-center text-base font-semibold text-carbon shadow-calida"
    >
      🐾 Reserva la estancia de tu perro
    </a>
    <a
      href="tel:697681869"
      class="toca mt-2.5 flex items-center justify-center gap-2 rounded-full border-2 border-terracota/60 px-5 py-3.5 text-center text-base font-semibold text-terracota"
    >
      📞 697 68 18 69
    </a>
  </nav>
</header>
<script>
  const btn = document.getElementById('btn-menu');
  const menu = document.getElementById('menu-movil');
  const backdrop = document.getElementById('menu-backdrop');
  const abrir = document.getElementById('icono-abrir');
  const cerrar = document.getElementById('icono-cerrar');

  function setMenu(mostrar) {
    if (!btn || !menu || !backdrop || !abrir || !cerrar) return;

    menu.classList.toggle('hidden', !mostrar);
    backdrop.classList.toggle('hidden', !mostrar);
    menu.setAttribute('data-abierto', String(mostrar));
    backdrop.setAttribute('data-abierto', String(mostrar));
    abrir.classList.toggle('hidden', mostrar);
    cerrar.classList.toggle('hidden', !mostrar);
    btn.setAttribute('aria-expanded', String(mostrar));
    btn.setAttribute('aria-label', mostrar ? 'Cerrar menú' : 'Abrir menú');
    document.body.classList.toggle('menu-abierto', mostrar);
  }

  function estaAbierto() {
    return menu ? !menu.classList.contains('hidden') : false;
  }

  if (btn) {
    btn.addEventListener('click', () => setMenu(!estaAbierto()));
  }

  if (backdrop) {
    backdrop.addEventListener('click', () => setMenu(false));
  }

  document.querySelectorAll('[data-link-movil]').forEach((el) => {
    el.addEventListener('click', () => setMenu(false));
  });

  // Cierra con Escape y al volver a escritorio
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && estaAbierto()) setMenu(false);
  });
  window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
    if (e.matches) setMenu(false);
  });
</script>
